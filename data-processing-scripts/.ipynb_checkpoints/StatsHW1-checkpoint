    "import pandas as pd\n",
    "import math\n",
    "\n",
    "def log_factorial(n):\n",
    "    return math.lgamma(n + 1)\n",
    "def probability(n):\n",
    "    # log(365!) - log((365-n)!) - n*log(365)\n",
    "    log_numerator = log_factorial(365) - log_factorial(365 - n)\n",
    "    log_denominator = n * math.log(365)\n",
    "    return 1 - math.exp(log_numerator - log_denominator)\n",
    "data = []\n",
    "for n in range(2, 101):  # days from 2 to 100\n",
    "    row = {\"n\": n,\"log(365!)\": log_factorial(365),\"log((365-n)!)\": log_factorial(365 - n),\"log(365^n)\": n * math.log(365),\"P(n)\": probability(n)}\n",
    "    data.append(row)\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "print(df.head(10))\n",
    "\n",
    "plt.figure(figsize=(8,5))\n",
    "plt.plot(df['n'],df['P(n)'], marker='o')\n",
    "plt.title(\"Probability of 2 People Sharing the Same Bday\")\n",
    "plt.xlabel(\"Size of Sample Pool (n)\")\n",
    "plt.ylabel(\"P(2 Same Bdays)\")\n",
    "plt.grid(True)\n",
    "plt.axhline(y=0.5,color='black')\n",
    "plt.show()"
   ]
